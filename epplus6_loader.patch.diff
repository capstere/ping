+function Resolve-EPPlus6Assemblies {
+    param(
+        [Parameter(Mandatory=$true)][string]$ModulesRoot,
+        [Parameter(Mandatory=$false)][string]$PreferredVersion = '6.2.7'
+    )
+
+    $paths = [ordered]@{
+        EPPlus      = $null
+        Interfaces  = $null
+        SystemDraw  = $null
+    }
+
+    $candidates = New-Object System.Collections.Generic.List[hashtable]
+
+    # 1) Config overrides (if present)
+    try {
+        if ($global:Config) {
+            if ($global:Config.EpplusDllPath) { $paths.EPPlus = ($global:Config.EpplusDllPath + '') }
+            if ($global:Config.EpplusInterfacesDllPath) { $paths.Interfaces = ($global:Config.EpplusInterfacesDllPath + '') }
+            if ($global:Config.EpplusSystemDrawingDllPath) { $paths.SystemDraw = ($global:Config.EpplusSystemDrawingDllPath + '') }
+        }
+    } catch {}
+
+    # If all three set and exist, return immediately
+    if ($paths.EPPlus -and $paths.Interfaces -and $paths.SystemDraw) {
+        if ((Test-Path -LiteralPath $paths.EPPlus) -and (Test-Path -LiteralPath $paths.Interfaces) -and (Test-Path -LiteralPath $paths.SystemDraw)) {
+            return $paths
+        }
+    }
+
+    # 2) Project LibRoot layouts (preferred for IPTCompile)
+    $roots = New-Object System.Collections.Generic.List[string]
+    try {
+        if ($global:LibRoot) { [void]$roots.Add(($global:LibRoot + '')) }
+    } catch {}
+    [void]$roots.Add((Join-Path $ModulesRoot '..\Lib'))
+    [void]$roots.Add((Join-Path $ModulesRoot '..\Modules'))  # legacy
+
+    foreach ($r in $roots) {
+        if (-not $r) { continue }
+        $r2 = (Resolve-Path -LiteralPath $r -ErrorAction SilentlyContinue)
+        if ($r2) { $r = $r2.Path }
+        # NuGet-like structure as in AutoMappscript
+        $ep = Join-Path $r ("EPPlus\EPPlus.$PreferredVersion\lib\net35\EPPlus.dll")
+        $ei = Join-Path $r ("EPPlus\EPPlus.Interfaces.6.1.1\lib\net35\EPPlus.Interfaces.dll")
+        $ed = Join-Path $r ("EPPlus\EPPlus.System.Drawing.6.1.1\lib\net35\EPPlus.System.Drawing.dll")
+        $candidates.Add(@{ EP=$ep; EI=$ei; ED=$ed }) | Out-Null
+
+        # Alternate: flat DLLs directly in LibRoot
+        $candidates.Add(@{
+            EP = (Join-Path $r 'EPPlus.dll')
+            EI = (Join-Path $r 'EPPlus.Interfaces.dll')
+            ED = (Join-Path $r 'EPPlus.System.Drawing.dll')
+        }) | Out-Null
+    }
+
+    foreach ($c in $candidates) {
+        if (-not $paths.EPPlus -and (Test-Path -LiteralPath $c.EP)) { $paths.EPPlus = $c.EP }
+        if (-not $paths.Interfaces -and (Test-Path -LiteralPath $c.EI)) { $paths.Interfaces = $c.EI }
+        if (-not $paths.SystemDraw -and (Test-Path -LiteralPath $c.ED)) { $paths.SystemDraw = $c.ED }
+
+        if ($paths.EPPlus -and $paths.Interfaces -and $paths.SystemDraw) { break }
+    }
+
+    return $paths
+}
